---
import { faq } from "../data/faq";
---

<section class="faq" id="faq">

  <div class="container">

    <p class="section-label">FAQ</p>

    <h2>Häufige Fragen.</h2>

    <p class="faq-intro">
      Hier findest du Antworten auf die wichtigsten Fragen rund um den
      Christopher Street Day Kulmbach.
    </p>

    <div class="faq-list">

      {faq.map((item) => (

        <details class="faq-item">

          <summary>

            <span>{item.question}</span>

            <span class="plus">+</span>

          </summary>

          {typeof item.answer === "string" ? (
  <p>{item.answer}</p>
) : (
  <div class="faq-answer">

    {item.answer.map((block, index) => (
      <div class="faq-block" key={index}>

        {block.intro && <p><strong>{block.intro}</strong></p>}

        {block.points && (
          <ul>
            {block.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        )}

        {block.outro && <p>{block.outro}</p>}

      </div>
    ))}

  </div>
)}

        </details>

      ))}

    </div>

  </div>

</section>