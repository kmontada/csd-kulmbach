---
import "../styles/globals.css";
import TopBar from "../components/TopBar.astro";
import Navigation from "../components/Navigation.astro";
import "../styles/topbar.css";
import "../styles/navigation.css";
import "../styles/layout.css";
import "../styles/hero.css";
import "../styles/highlights.css";
import "../styles/about.css";
import "../styles/program.css";
import "../styles/route.css";
import "../styles/participate.css";
import "../styles/faq.css";
import "../styles/sponsors.css";
import "../styles/footer.css";
---
<!doctype html>
<html lang="de">
	<head>
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" href="/favicon.png" />

  <meta charset="utf-8" />

  <title>CSD Kulmbach 2026 – Vielfalt, Sichtbarkeit & Respekt</title>

  <meta name="description" content="Der Christopher Street Day Kulmbach 2026 – gemeinsam für Vielfalt, Respekt und Sichtbarkeit in Kulmbach." />

  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <meta name="robots" content="index, follow" />

  <!-- OPEN GRAPH (Facebook, WhatsApp, Discord) -->

  <meta property="og:title" content="CSD Kulmbach 2026 – Vielfalt, Sichtbarkeit & Respekt" />

  <meta property="og:description" content="Vielfalt, Sichtbarkeit und Respekt – Christopher Street Day Kulmbach 2026." />

  <meta property="og:type" content="website" />

  <meta property="og:url" content="https://csd-kulmbach.de" />

  <!-- OG IMAGE (DEIN FLYER) -->

  <meta property="og:image" content="https://csd-kulmbach.de/images/flyer-2026.jpeg" />

  <meta property="og:image:width" content="1200" />

  <meta property="og:image:height" content="630" />

  <!-- TWITTER / X -->

  <meta name="twitter:card" content="summary_large_image" />

  <meta name="twitter:title" content="CSD Kulmbach 2026 – Vielfalt, Sichtbarkeit & Respekt" />

  <meta name="twitter:description" content="Vielfalt, Sichtbarkeit und Respekt in Kulmbach." />

  <meta name="twitter:image" content="https://csd-kulmbach.de/images/flyer-2026.jpeg" />

  <!-- STRUCTURED DATA (EVENT) -->

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "CSD Kulmbach 2026 – Christopher Street Day",

  "description": "Der Christopher Street Day Kulmbach 2026 steht für Vielfalt, Sichtbarkeit und Respekt. Gemeinsam für LGBTQ+ Rechte in Kulmbach und der Region.",

  "startDate": "2026-08-29T14:00:00+02:00",
  "endDate": "2026-08-30T00:00:00+02:00",

  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",

  "location": {
    "@type": "Place",
    "name": "Kulmbach – Innenstadt",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Kulmbach",
      "addressRegion": "Bayern",
      "postalCode": "95326",
      "addressCountry": "DE"
    }
  },

  "organizer": {
    "@type": "Organization",
    "name": "CSD Kulmbach Organisationsteam",
    "url": "https://csd-kulmbach.de"
  },

  "performer": {
    "@type": "Organization",
    "name": "CSD Kulmbach Community"
  },

  "image": [
    "https://csd-kulmbach.de/images/flyer-2026.jpeg"
  ],

  "keywords": "CSD Kulmbach, Christopher Street Day Kulmbach, Pride Kulmbach, LGBTQ+ Kulmbach, Bayern Pride"
}
</script>

</head>
	<body>
 <TopBar />
<Navigation />
  <slot />
</body>
</html>

<style>

	:root {
		/* Farben */
		--primary: #c42cb8;
		--primary-dark: #6a1d8f;
		--accent: #f2d43d;
		--background: #fff9f2;
		--surface: #ffffff;
		--text: #1d1d1f;
		--text-light: #666666;
		/* Layout */
		--radius: 18px;
		--shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
		--max-width: 1200px;
	}
	* {
		box-sizing: border-box;
	}
	html {
		scroll-behavior: smooth;
	}
	body {
		margin: 0;
		min-height: 100vh;
		font-family:
			Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		background: var(--background);
		color: var(--text);
	}

</style>

